DEFAULT_IMAGE=ubuntu:24.04
DEFAULT_CONTAINER_ALIAS=default
DEFAULT_IMAGE_PULL=if-missing   # always|if-missing|never
WORKSPACE_ROOT=/workspace
SQLITE_PATH=./state.db
DOCKER_HOST=unix:///var/run/docker.sock
LOG_LEVEL=INFO

# FastMCP2 transport
MCP_TRANSPORT=http
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8765
